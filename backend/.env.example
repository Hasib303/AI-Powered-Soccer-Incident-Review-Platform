# Atletico backend environment

# FastAPI
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=info

# CORS — comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# When false, JWT validation is skipped (good for local dev). Set to true in
# production so every endpoint requires a valid Supabase user token.
AUTH_REQUIRED=false

# Storage bucket names (Supabase Storage)
CLIPS_BUCKET=clips
SNAPSHOTS_BUCKET=snapshots

# YOLO
YOLO_MODEL=yolov8n.pt
YOLO_PERSON_CONFIDENCE=0.2
YOLO_BALL_CONFIDENCE=0.4
YOLO_IMGSZ=1920

# Confidence threshold under which the verdict becomes human_review_required
HUMAN_REVIEW_THRESHOLD=0.6

# Path prefix where sample clips and calibration JSONs live
SAMPLES_DIR=samples
