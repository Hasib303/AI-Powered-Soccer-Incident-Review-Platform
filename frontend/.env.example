# Atletico Intelligence — frontend environment

# --- Supabase (browser-safe) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Supabase (server-only) ---
# Used only in server actions / route handlers — never exposed to the client.
SUPABASE_SERVICE_ROLE_KEY=

# --- Atletico AI/CV service ---
# URL of the Python FastAPI service. Local dev = http://127.0.0.1:8000
# Production = your Hugging Face Space URL.
AI_SERVICE_URL=http://127.0.0.1:8000

# --- Demo data ---
# When you create the seeded match, paste its UUID here so the live console
# can default to it. Optional; the assignments list also surfaces it.
NEXT_PUBLIC_DEMO_MATCH_ID=00000000-0000-0000-0000-000000000030
